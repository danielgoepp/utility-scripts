# Path to the Home Lab markdown note
NOTE_PATH=~/Notes/Information Technology/README.md

# kubectl context for the prod cluster
K3S_CONTEXT=k3s-prod

# Proxmox node to SSH into for ZFS pool data
PVE_STORAGE_HOST=pve15

# SSH user for Proxmox nodes
PVE_SSH_USER=root

# SSH key path (leave blank to use system default / ssh-agent)
SSH_KEY_PATH=

# SSH connection timeout in seconds
SSH_TIMEOUT=10
