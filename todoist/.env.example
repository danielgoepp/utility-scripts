# Personal API token (Settings > Integrations > Developer) — used to download backup files
TODOIST_API_TOKEN=your-personal-api-token-here

# OAuth app credentials — required to list backups (bypasses MFA requirement)
# Create an app at https://app.todoist.com/app/settings/integrations/app-management
# Set the redirect URI to any HTTPS URL you control, e.g. https://localhost
TODOIST_CLIENT_ID=your-client-id-here
TODOIST_CLIENT_SECRET=your-client-secret-here
TODOIST_OAUTH_REDIRECT_URI=https://localhost

# Saved automatically by setup-oauth.py; do not edit manually
TODOIST_OAUTH_TOKEN=
