# Comma-separated list of Kopia instance names
KOPIA_INSTANCES=b2,ssd,hdd

# Per-instance configuration
KOPIA_B2_SERVER_URL=
KOPIA_B2_CONTROL_USERNAME=server-control
KOPIA_B2_CONTROL_PASSWORD=

KOPIA_SSD_SERVER_URL=
KOPIA_SSD_CONTROL_USERNAME=server-control
KOPIA_SSD_CONTROL_PASSWORD=

KOPIA_HDD_SERVER_URL=
KOPIA_HDD_CONTROL_USERNAME=server-control
KOPIA_HDD_CONTROL_PASSWORD=

# Maximum age in hours before a snapshot is considered stale (default: 26)
KOPIA_MAX_SNAPSHOT_AGE_HOURS=26

# TLS verification (set to "false" for self-signed certificates)
KOPIA_VERIFY_TLS=true
